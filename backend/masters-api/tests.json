{
  "tests": [
    {
      "name": "Список мастеров (публичный)",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список специализаций",
      "method": "GET",
      "path": "/?specializations=1",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список мастеров для админа — без токена",
      "method": "GET",
      "path": "/?admin=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Мой профиль — без токена",
      "method": "GET",
      "path": "/?me=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Обновить профиль — без токена",
      "method": "PUT",
      "path": "/?me=1",
      "body": {"name": "Test"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — слоты (GET без данных)",
      "method": "GET",
      "path": "/?resource=calendar&sub=slots&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — настройки (дефолтные)",
      "method": "GET",
      "path": "/?resource=calendar&sub=settings&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"default_slot_duration": 60},
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — week-view",
      "method": "GET",
      "path": "/?resource=calendar&sub=week-view&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"slots": [], "bookings": [], "blocks": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Записи — пустой список",
      "method": "GET",
      "path": "/?resource=bookings&sub=bookings&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Записи — статистика",
      "method": "GET",
      "path": "/?resource=bookings&sub=stats&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"occupancy_percent": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Отзывы — пустой список",
      "method": "GET",
      "path": "/?resource=reviews&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — очистка (для несуществующего мастера)",
      "method": "POST",
      "path": "/?resource=calendar&sub=clear",
      "body": {"master_id": 999999, "scope": "all"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — слоты без master_id отвечают 400",
      "method": "GET",
      "path": "/?resource=calendar&sub=slots",
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Записи — без master_id отвечают 400",
      "method": "GET",
      "path": "/?resource=bookings&sub=bookings",
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — POST без master_id отвечает 400",
      "method": "POST",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"client_name": "Тест", "client_phone": "+7", "datetime_start": "2099-01-01T10:00:00+03:00", "datetime_end": "2099-01-01T11:00:00+03:00"},
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — reschedule без datetime отвечает 400",
      "method": "PUT",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"id": 999999999, "action": "reschedule"},
      "expectedStatus": 400,
      "expectedBody": {"error": "missing_datetime"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — reschedule несуществующей возвращает 404",
      "method": "PUT",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"id": 999999999, "action": "reschedule", "datetime_start": "2099-01-01T10:00:00+03:00", "datetime_end": "2099-01-01T11:00:00+03:00"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Бронь не найдена"},
      "bodyMatcher": "partial"
    }
  ]
}