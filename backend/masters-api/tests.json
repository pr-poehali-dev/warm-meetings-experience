{
  "tests": [
    {
      "name": "Список мастеров (публичный)",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"masters": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список специализаций",
      "method": "GET",
      "path": "/?specializations=1",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список мастеров для админа — без токена",
      "method": "GET",
      "path": "/?admin=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Мой профиль — без токена",
      "method": "GET",
      "path": "/?me=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Обновить профиль — без токена",
      "method": "PUT",
      "path": "/?me=1",
      "body": {"name": "Test"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    }
  ]
}