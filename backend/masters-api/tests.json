{
  "tests": [
    {
      "name": "Список мастеров (публичный)",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список специализаций",
      "method": "GET",
      "path": "/?specializations=1",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список мастеров для админа — без токена",
      "method": "GET",
      "path": "/?admin=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Мой профиль — без токена",
      "method": "GET",
      "path": "/?me=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Обновить профиль — без токена",
      "method": "PUT",
      "path": "/?me=1",
      "body": {"name": "Test"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — слоты (GET без данных)",
      "method": "GET",
      "path": "/?resource=calendar&sub=slots&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — настройки (дефолтные)",
      "method": "GET",
      "path": "/?resource=calendar&sub=settings&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"default_slot_duration": 60},
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — week-view",
      "method": "GET",
      "path": "/?resource=calendar&sub=week-view&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"slots": [], "bookings": [], "blocks": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Записи — пустой список",
      "method": "GET",
      "path": "/?resource=bookings&sub=bookings&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Записи — статистика",
      "method": "GET",
      "path": "/?resource=bookings&sub=stats&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"occupancy_percent": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Отзывы — пустой список",
      "method": "GET",
      "path": "/?resource=reviews&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — очистка (для несуществующего мастера)",
      "method": "POST",
      "path": "/?resource=calendar&sub=clear",
      "body": {"master_id": 999999, "scope": "all"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Календарь — слоты без master_id отвечают 400",
      "method": "GET",
      "path": "/?resource=calendar&sub=slots",
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Записи — без master_id отвечают 400",
      "method": "GET",
      "path": "/?resource=bookings&sub=bookings",
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — POST без master_id отвечает 400",
      "method": "POST",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"client_name": "Тест", "client_phone": "+7", "datetime_start": "2099-01-01T10:00:00+03:00", "datetime_end": "2099-01-01T11:00:00+03:00"},
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — reschedule без datetime отвечает 400",
      "method": "PUT",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"id": 999999999, "action": "reschedule"},
      "expectedStatus": 400,
      "expectedBody": {"error": "missing_datetime"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — reschedule несуществующей возвращает 404",
      "method": "PUT",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"id": 999999999, "action": "reschedule", "datetime_start": "2099-01-01T10:00:00+03:00", "datetime_end": "2099-01-01T11:00:00+03:00"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Бронь не найдена"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бронь — POST с master_id без токена возвращает 401/403/404",
      "method": "POST",
      "path": "/?resource=bookings&sub=bookings",
      "body": {"master_id": 999999, "client_name": "Тест", "client_phone": "+7", "datetime_start": "2099-01-01T10:00:00+03:00", "datetime_end": "2099-01-01T11:00:00+03:00"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Apply-template — без master_id возвращает 400",
      "method": "POST",
      "path": "/?resource=calendar&sub=apply-template",
      "body": {"template_id": 999999, "weeks": 1},
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Apply-template — несуществующий шаблон возвращает 404",
      "method": "POST",
      "path": "/?resource=calendar&sub=apply-template",
      "body": {"master_id": 999999, "template_id": 999999999, "weeks": 1},
      "expectedStatus": 404,
      "expectedBody": {"error": "Шаблон не найден или пустой"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Public-book — без slot_id возвращает 400",
      "method": "POST",
      "path": "/?resource=bookings&sub=public-book",
      "body": {"client_name": "Иван", "client_phone": "+79991234567"},
      "expectedStatus": 400,
      "expectedBody": {"error": "missing_slot"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Public-book — короткий телефон возвращает 400",
      "method": "POST",
      "path": "/?resource=bookings&sub=public-book",
      "body": {"slot_id": 999999, "client_name": "Иван", "client_phone": "+7"},
      "expectedStatus": 400,
      "expectedBody": {"error": "invalid_phone"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Public-book — несуществующий слот возвращает 404",
      "method": "POST",
      "path": "/?resource=bookings&sub=public-book",
      "body": {"slot_id": 999999999, "client_name": "Иван", "client_phone": "+79991234567"},
      "expectedStatus": 404,
      "expectedBody": {"error": "Интервал не найден"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Корзина — список (пустые брони для несуществующего мастера)",
      "method": "GET",
      "path": "/?resource=calendar&sub=trash&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"bookings": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Корзина — без master_id отвечает 400",
      "method": "GET",
      "path": "/?resource=calendar&sub=trash",
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Восстановление — без master_id отвечает 400",
      "method": "POST",
      "path": "/?resource=calendar&sub=restore",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Восстановление — GET не поддерживается (405)",
      "method": "GET",
      "path": "/?resource=calendar&sub=restore&master_id=999999",
      "expectedStatus": 405,
      "expectedBody": {"error": "Method not allowed"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Бэкап — GET не поддерживается (405)",
      "method": "GET",
      "path": "/?resource=calendar&sub=backup&master_id=999999",
      "expectedStatus": 405,
      "expectedBody": {"error": "Method not allowed"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Адреса — список (пустой для несуществующего мастера)",
      "method": "GET",
      "path": "/?resource=calendar&sub=addresses&master_id=999999",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "partial"
    },
    {
      "name": "Адреса — GET без master_id отвечает 400",
      "method": "GET",
      "path": "/?resource=calendar&sub=addresses",
      "expectedStatus": 400,
      "expectedBody": {"error": "master_id обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Адреса — POST с master_id без токена отвечает 401",
      "method": "POST",
      "path": "/?resource=calendar&sub=addresses",
      "body": {"master_id": 999999, "address_text": "ул. Ленина, 10"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Адрес основной — GET не поддерживается (405)",
      "method": "GET",
      "path": "/?resource=calendar&sub=set-primary-address",
      "expectedStatus": 405,
      "expectedBody": {"error": "POST only"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Ключ карт — GET возвращает apikey",
      "method": "GET",
      "path": "/?resource=calendar&sub=maps-key",
      "expectedStatus": 200,
      "expectedBody": {"apikey": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Геокодер — без q и координат отвечает 400",
      "method": "GET",
      "path": "/?resource=calendar&sub=geocode",
      "expectedStatus": 400,
      "expectedBody": {"error": "q или lat/lng обязательны"},
      "bodyMatcher": "partial"
    }
  ]
}