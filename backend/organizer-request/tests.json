{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST without name fails",
      "method": "POST",
      "path": "/",
      "body": {"telegram": "@test", "email": "test@test.com"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST without telegram fails",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест", "email": "test@test.com"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST without email fails",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест", "telegram": "@test"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST with existing email returns 400",
      "method": "POST",
      "path": "/",
      "body": {
        "name": "Тест Организатор",
        "telegram": "@test_org_auto",
        "email": "test_auto_org_reg@organizer.com",
        "city": "Москва",
        "has_own_bath": "no",
        "event_format": "Тестовый формат",
        "additional_info": "Тест"
      },
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}