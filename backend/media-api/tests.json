{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET external videos (empty)",
      "method": "GET",
      "path": "/?videos=1&owner_type=master&owner_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"videos": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST без файла — ошибка",
      "method": "POST",
      "path": "/",
      "body": {"folder": "events"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Файл не передан"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET event_media без event_id — ошибка",
      "method": "GET",
      "path": "/?event_media=1",
      "expectedStatus": 400,
      "expectedBody": {"error": "Не указан event_id"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET event_media список",
      "method": "GET",
      "path": "/?event_media=1&event_id=999999",
      "expectedStatus": 200,
      "expectedBody": {"media": []},
      "bodyMatcher": "partial"
    }
  ]
}