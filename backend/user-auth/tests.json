{
  "tests": [
    {
      "name": "OPTIONS returns 200",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Login without credentials returns 400",
      "method": "POST",
      "path": "/?action=login",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong email returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "nonexistent@test.ru", "password": "wrong12345"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register without consent returns 400",
