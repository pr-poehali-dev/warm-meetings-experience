{
  "tests": [
    {
      "name": "Get all baths",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"baths": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get bath by slug not found",
      "method": "GET",
      "path": "/?slug=nonexistent-slug-12345",
      "expectedStatus": 404,
      "expectedBody": {"error": "Баня не найдена"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Search baths",
      "method": "GET",
      "path": "/?search=баня",
      "expectedStatus": 200,
      "expectedBody": {"baths": []},
      "bodyMatcher": "partial"
    }
  ]
}
