{
  "tests": [
    {
      "name": "Get all visible events",
      "method": "GET",
      "path": "/?resource=events&visible=true",
      "expectedStatus": 200
    },
    {
      "name": "Get all events including hidden",
      "method": "GET",
      "path": "/?resource=events&visible=all",
      "expectedStatus": 200
    },
    {
      "name": "Get event by slug not found",
      "method": "GET",
      "path": "/?resource=events&slug=nonexistent-slug-12345",
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get event by short_code not found",
      "method": "GET",
      "path": "/?resource=events&short_code=xxxxxx",
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get signups list",
      "method": "GET",
      "path": "/?resource=signups",
      "expectedStatus": 200
    },
    {
      "name": "Create signup without consent returns 400",
      "method": "POST",
      "path": "/?resource=signups",
      "body": {"event_id": 1, "name": "Test", "phone": "+79991234567", "email": "test@test.ru", "consent_pd": false},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create signup without email returns 400",
      "method": "POST",
      "path": "/?resource=signups",
      "body": {"event_id": 1, "name": "Test", "phone": "+79991234567"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Honeypot triggered returns 200 silently",
      "method": "POST",
      "path": "/?resource=signups",
      "body": {"event_id": 1, "name": "Bot", "phone": "+79990000000", "email": "bot@bot.ru", "consent_pd": true, "website": "http://spam.com"},
      "expectedStatus": 200
    },
    {
      "name": "Form filled too fast returns 400",
      "method": "POST",
      "path": "/?resource=signups",
      "body": {"event_id": 1, "name": "Fast", "phone": "+79990000001", "email": "fast@test.ru", "consent_pd": true, "form_open_ms": 500},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}