{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get scenarios without token returns 401",
      "method": "GET",
      "path": "/?resource=scenarios",
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Необходима авторизация"}
    },
    {
      "name": "Get recipients without token returns 401",
      "method": "GET",
      "path": "/?resource=recipients&event_id=1",
      "expectedStatus": 401
    },
    {
      "name": "Send without token returns 401",
      "method": "POST",
      "path": "/?resource=send",
      "expectedStatus": 401
    },
    {
      "name": "Get log without token returns 401",
      "method": "GET",
      "path": "/?resource=log",
      "expectedStatus": 401
    },
    {
      "name": "Unknown resource returns 404",
      "method": "GET",
      "path": "/?resource=unknown",
      "expectedStatus": 401
    },
    {
      "name": "Master bookings list without token returns 401",
      "method": "GET",
      "path": "/?resource=master_bookings",
      "expectedStatus": 401
    },
    {
      "name": "Master booking recipients without token returns 401",
      "method": "GET",
      "path": "/?resource=recipients&source=master_booking",
      "expectedStatus": 401
    },
    {
      "name": "Partner events list without token returns 401",
      "method": "GET",
      "path": "/?resource=partner_events",
      "expectedStatus": 401
    },
    {
      "name": "Ritual bookings list without token returns 401",
      "method": "GET",
      "path": "/?resource=ritual_bookings",
      "expectedStatus": 401
    },
    {
      "name": "Ritual booking recipients without token returns 401",
      "method": "GET",
      "path": "/?resource=recipients&source=ritual_booking",
      "expectedStatus": 401
    },
    {
      "name": "Каналы — channels без токена",
      "method": "GET",
      "path": "/?action=channels",
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Необходима авторизация"}
    },
    {
      "name": "Каналы — set_channel без токена",
      "method": "POST",
      "path": "/?action=set_channel",
      "body": {"channel": "email", "active": true},
      "expectedStatus": 401
    },
    {
      "name": "Каналы — set_prefs без токена",
      "method": "POST",
      "path": "/?action=set_prefs",
      "body": {"channel": "vk"},
      "expectedStatus": 401
    },
    {
      "name": "Каналы — allow_vk без токена",
      "method": "POST",
      "path": "/?action=allow_vk",
      "body": {"allow": true},
      "expectedStatus": 401
    },
    {
      "name": "Каналы — send_broadcast без пароля",
      "method": "POST",
      "path": "/?action=send_broadcast",
      "body": {"message": "test"},
      "expectedStatus": 403
    },
    {
      "name": "Центр — notify_center без токена",
      "method": "GET",
      "path": "/?action=notify_center",
      "expectedStatus": 401
    },
    {
      "name": "Центр — set_event_sub без токена",
      "method": "POST",
      "path": "/?action=set_event_sub",
      "body": {"event_type": "master_booking_new", "enabled": true},
      "expectedStatus": 401
    },
    {
      "name": "Центр — set_schedule без токена",
      "method": "POST",
      "path": "/?action=set_schedule",
      "body": {"quiet_enabled": true, "quiet_from": 22, "quiet_to": 8},
      "expectedStatus": 401
    }
  ]
}